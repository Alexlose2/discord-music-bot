DISCORD_TOKEN=pon_aqui_el_token_de_tu_bot
# Opcional: para que los comandos slash aparezcan al instante en un servidor.
# Copia el ID de tu servidor de Discord y quita el #.
# GUILD_ID=123456789012345678

# Opcional: necesario para enlaces de Spotify.
# SPOTIFY_CLIENT_ID=pon_aqui_tu_client_id
# SPOTIFY_CLIENT_SECRET=pon_aqui_tu_client_secret

# Opcional: maximo de canciones que cargara desde una playlist/album de Spotify.
# MAX_SPOTIFY_TRACKS=50
